// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum SocialPlatform {
  x
  instagram
  reddit
  linkedin
  tiktok
  bluesky
  threads
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum PostIntegrationStatus {
  PENDING
  PUBLISHED
  FAILED
}

enum WebhookEvent {
  post_published
  post_failed
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  apiKey      String   @unique @default(cuid())
  paymentId   String?
  isTrialing  Boolean  @default(true)
  /// Monthly post quota (null = unlimited)
  postQuota   Int?     @default(100)
  /// Posts used this calendar month
  postsUsed   Int      @default(0)
  /// When the quota window last reset (start of month)
  quotaResetAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        UserOrganization[]
  integrations Integration[]
  posts        Post[]
  oauthStates  OAuthState[]
  webhooks     Webhook[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  providerName String?
  timezone     String   @default("UTC")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizations UserOrganization[]
}

model UserOrganization {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           UserRole @default(MEMBER)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Integration {
  id             String         @id @default(cuid())
  organizationId String
  token          String
  refreshToken   String?
  internalId     String
  identifier     SocialPlatform
  disabled       Boolean        @default(false)
  /// Human-readable handle / username on the platform
  handle         String?
  /// Display name on the platform
  displayName    String?
  /// Platform profile picture URL
  avatarUrl      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  postIntegrations PostIntegration[]

  @@unique([organizationId, identifier, internalId])
  @@index([organizationId])
}

model Post {
  id             String     @id @default(cuid())
  organizationId String
  content        String
  /// JSON-encoded options (subreddit, title, imageUrl, etc.)
  options        Json?
  scheduledAt    DateTime?
  publishedAt    DateTime?
  status         PostStatus @default(DRAFT)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  postIntegrations PostIntegration[]

  @@index([organizationId, status])
  @@index([scheduledAt, status])
}

model PostIntegration {
  id            String                @id @default(cuid())
  postId        String
  integrationId String
  status        PostIntegrationStatus @default(PENDING)
  error         String?
  externalId    String?
  /// Public URL to the published post
  url           String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  post        Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([postId, integrationId])
  @@index([integrationId])
}

/// Ephemeral OAuth state for PKCE + CSRF protection.
/// Created at auth URL generation, deleted after callback.
model OAuthState {
  id             String         @id @default(cuid())
  organizationId String
  platform       SocialPlatform
  /// CSRF state token (random, opaque, stored as the OAuth `state` param)
  state          String         @unique
  /// PKCE code verifier (for platforms using PKCE — X, Reddit)
  codeVerifier   String?
  /// Where to redirect the user after OAuth success
  redirectUri    String
  expiresAt      DateTime
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([state])
  @@index([expiresAt])
}

/// Webhook endpoints registered by an org to receive post events.
model Webhook {
  id             String       @id @default(cuid())
  organizationId String
  /// HTTPS URL to POST events to
  url            String
  /// Which events to fire for (empty = all)
  events         WebhookEvent[]
  /// Secret for HMAC-SHA256 signature header (X-SocialAgent-Signature)
  secret         String
  enabled        Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}
