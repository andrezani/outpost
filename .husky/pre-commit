#!/bin/sh

# SocialAgent pre-commit hook
# Ensures: (1) Prisma client is up to date (2) TypeScript is clean before every commit

echo "⚙️  Running pre-commit checks..."

# 1. Regenerate Prisma client (prevents stale-client bugs after schema changes)
echo "📦 prisma generate..."
npx prisma generate 2>&1

# 2. TypeScript check — MUST be 0 errors
echo "🔍 tsc --noEmit..."
node node_modules/typescript/bin/tsc --noEmit -p tsconfig.json

if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors found. Fix before committing."
  exit 1
fi

echo "✅ Pre-commit checks passed."
