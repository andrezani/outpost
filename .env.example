# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/outpost"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN="*"

# ─── Scheduler ───────────────────────────────────────────────────────────────
SCHEDULER_INTERVAL_MS=60000   # Poll interval for due posts (ms). Default: 60s

# ─── X (Twitter) — OAuth 2.0 PKCE ────────────────────────────────────────────
# Create app: https://developer.twitter.com/en/apps
# ⚠️ Add your callback URL to the Twitter app before testing OAuth
X_CLIENT_ID="your-x-client-id"
X_CLIENT_SECRET="your-x-client-secret"

# ─── Reddit — OAuth 2.0 ──────────────────────────────────────────────────────
# Create app: https://www.reddit.com/prefs/apps (type: "web app")
REDDIT_CLIENT_ID="your-reddit-client-id"
REDDIT_CLIENT_SECRET="your-reddit-client-secret"

# ─── Instagram + Threads (Meta Graph API) ────────────────────────────────────
# Create app: https://developers.facebook.com/apps/
# ⚠️ Use "Other/legacy" app type — new use-case wizard attaches deprecated scopes
INSTAGRAM_CLIENT_ID="your-meta-app-id"
INSTAGRAM_CLIENT_SECRET="your-meta-app-secret"

# Threads uses the same Meta app as Instagram
THREADS_CLIENT_ID="your-meta-app-id"
THREADS_CLIENT_SECRET="your-meta-app-secret"

# ─── LinkedIn — OAuth 2.0 ────────────────────────────────────────────────────
# Create app: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"

# ─── Bluesky ─────────────────────────────────────────────────────────────────
# No OAuth client needed — users connect via app password
# See: https://bsky.app/settings/app-passwords

# ─── Stripe Billing ───────────────────────────────────────────────────────────
# Create account: https://dashboard.stripe.com/
# ⚠️ Use test keys (sk_test_...) for development, live keys for production.
# If not set, billing endpoints return a 400 with a clear message — app still works.
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"

# Stripe Price IDs — create products in Stripe Dashboard:
#   Pro:      $29/mo  → Products → Add product → Recurring $29
#   Team:     $99/mo  → Products → Add product → Recurring $99
#   Founding: $49/mo  → Products → Add product → Recurring $49 (limited)
STRIPE_PRO_PRICE_ID="price_pro_placeholder"
STRIPE_TEAM_PRICE_ID="price_team_placeholder"
STRIPE_FOUNDING_PRICE_ID="price_founding_placeholder"

# ─── MCP Server (standalone mode) ────────────────────────────────────────────
OUTPOST_BASE_URL="http://localhost:3000"
# OUTPOST_API_KEY="sa_xxx"   # Set when running mcp-server.js standalone

# ─── Inngest (reserved for future scheduled publishing) ──────────────────────
# INNGEST_EVENT_KEY="your-inngest-event-key"
# INNGEST_SIGNING_KEY="your-inngest-signing-key"
