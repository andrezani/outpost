# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/socialagent"

# Redis
REDIS_URL="redis://localhost:6379"

# Inngest (reserved for future use — currently using in-process scheduler)
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# App
PORT=3000
NODE_ENV=development
CORS_ORIGIN="*"

# Scheduler
SCHEDULER_INTERVAL_MS=60000   # How often to poll for due posts (ms). Default: 60s

# ─────────────────────────────────────────────
# Social Platform Credentials
# ─────────────────────────────────────────────

# X (Twitter) — OAuth 2.0 PKCE
# Create app: https://developer.twitter.com/en/apps
X_CLIENT_ID="your-x-client-id"
X_CLIENT_SECRET="your-x-client-secret"

# Reddit — OAuth 2.0 script app
# Create app: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID="your-reddit-client-id"
REDDIT_CLIENT_SECRET="your-reddit-client-secret"

# LinkedIn — coming soon
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""

# Instagram (Meta Graph API) — coming soon
# META_APP_ID=""
# META_APP_SECRET=""

# TikTok — coming soon
# TIKTOK_CLIENT_KEY=""
# TIKTOK_CLIENT_SECRET=""
